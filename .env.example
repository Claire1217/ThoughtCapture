# ThoughtCapture Configuration

# Storage backend: "obsidian" (default) or "notes" (Apple Notes)
STORAGE_BACKEND=obsidian

# Path to your Obsidian vault (ignored if STORAGE_BACKEND=notes)
VAULT_PATH=~/obsidian
# Vault name as shown in Obsidian (used for deep links)
VAULT_NAME=obsidian

# LLM API (any OpenAI-compatible endpoint). Leave blank to disable AI features.
LLM_API_KEY=
LLM_API_BASE=https://api.deepseek.com/chat/completions
LLM_MODEL=deepseek-chat

# Server port
PORT=19876
